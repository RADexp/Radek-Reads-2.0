---
import type { Format } from '../lib/types';

interface Props {
  format: Format;
  size?: number;
  color?: string;
}
const { format, size = 12, color = 'currentColor' } = Astro.props;
---

{format === 'audiobook' && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke={color}
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    style="display:inline-block; vertical-align:-2px"
  >
    <path d="M3 18v-6a9 9 0 0 1 18 0v6" /><path
      d="M21 19a2 2 0 0 1-2 2h-1v-6h3zM3 19a2 2 0 0 0 2 2h1v-6H3z"
    />
  </svg>
)}
{format === 'ebook' && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke={color}
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    style="display:inline-block; vertical-align:-2px"
  >
    <rect x="5" y="3" width="14" height="18" rx="1.5" /><line x1="8" y1="7" x2="16" y2="7" /><line
      x1="8"
      y1="11"
      x2="16"
      y2="11"
    />
  </svg>
)}
{format === 'paper' && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke={color}
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    style="display:inline-block; vertical-align:-2px"
  >
    <path d="M4 4h11a4 4 0 0 1 4 4v12H8a4 4 0 0 1-4-4z" /><path d="M4 16a4 4 0 0 1 4-4h11" />
  </svg>
)}
