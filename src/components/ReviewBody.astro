---
// Renderuje sparsowane bloki Notion (notion-blocks.ts) na semantyczny HTML.
import type { ReviewBlock } from '../lib/types';

interface Props {
  blocks: ReviewBlock[];
}
const { blocks } = Astro.props;
---

<div class="rr-review-body">
  {blocks.map((b) => {
    if (b.type === 'h1') return <h1 set:html={b.html} />;
    if (b.type === 'h2') return <h2 set:html={b.html} />;
    if (b.type === 'h3') return <h3 set:html={b.html} />;
    if (b.type === 'ul')
      return (
        <ul>
          {b.items?.map((item) => <li set:html={item} />)}
        </ul>
      );
    if (b.type === 'youtube')
      return (
        <div class="rr-yt-embed">
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${b.youtubeId}`}
            title="YouTube video"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        </div>
      );
    return <p set:html={b.html} />;
  })}
</div>

<style>
  .rr-review-body :global(h1) {
    margin: 28px 0 12px;
    font-family: var(--rr-sans);
    font-weight: 700;
    font-size: 26px;
    letter-spacing: -0.03em;
    color: var(--rr-ink);
    line-height: 1.05;
  }
  .rr-review-body :global(h2) {
    margin: 28px 0 12px;
    font-family: var(--rr-sans);
    font-weight: 700;
    font-size: 26px;
    letter-spacing: -0.03em;
    color: var(--rr-ink);
    line-height: 1.05;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .rr-review-body :global(h2)::before {
    content: '';
    display: block;
    width: 9px;
    height: 9px;
    border-radius: 2px;
    flex-shrink: 0;
    background: oklch(0.82 0.16 var(--hue));
    box-shadow: 0 0 12px oklch(0.82 0.16 var(--hue) / 0.8);
  }
  .rr-review-body :global(h3) {
    margin: 22px 0 6px;
    font-family: var(--rr-mono);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rr-accent);
  }
  .rr-review-body :global(p) {
    margin: 0 0 14px;
    font-family: var(--rr-sans);
    font-size: 16px;
    line-height: 1.62;
    color: #d8d3f0;
  }
  .rr-review-body :global(ul) {
    margin: 0 0 14px;
    padding-left: 22px;
    font-family: var(--rr-sans);
    font-size: 16px;
    line-height: 1.62;
    color: #d8d3f0;
  }
  .rr-review-body :global(a) {
    color: var(--rr-accent-2);
    text-decoration-color: rgba(167, 139, 250, 0.4);
  }
  .rr-yt-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    margin: 8px 0 20px;
    background: var(--rr-bg-2);
  }
  .rr-yt-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
