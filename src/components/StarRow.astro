---
interface Props {
  value: number;
  size?: number;
  color?: string;
  muted?: string;
}
const { value = 0, size = 12, color = 'currentColor', muted = 'rgba(255,255,255,.15)' } = Astro.props;
const stars = [1, 2, 3, 4, 5];
---

<span class="rr-stars" style={`display:inline-flex; gap:1px; line-height:1; color:${color}`}>
  {stars.map((n) => (
    <svg width={size} height={size} viewBox="0 0 20 20" style="display:block">
      <path
        d="M10 1.6l2.6 5.3 5.9.86-4.25 4.14 1 5.86L10 14.98l-5.25 2.78 1-5.86L1.5 7.76l5.9-.86z"
        fill={n <= value ? color : muted}
      />
    </svg>
  ))}
</span>
