---
// CReadCard z designs/variants/variant-c.jsx — karta w gęstej siatce "Przeczytane".
import BookCover from './BookCover.astro';
import GenreTag from './GenreTag.astro';
import StarRow from './StarRow.astro';
import FormatIcon from './FormatIcon.astro';
import LangFlag from './LangFlag.astro';
import { genreInfo } from '../data/genres';
import type { Book } from '../lib/types';

interface Props {
  book: Book;
}
const { book } = Astro.props;
const hue = genreInfo(book.genre).hue;
const accentColor = `oklch(0.82 0.16 ${hue})`;
---

<a
  href={`/recenzje/${book.id}`}
  class="rr-read-card"
  style={`--hue:${hue}`}
  data-genre={book.genre}
  data-lang-val={book.lang}
  data-format={book.format}
  data-rating-4plus={(book.rating ?? 0) >= 4 ? '1' : '0'}
  data-rating-5={(book.rating ?? 0) >= 5 ? '1' : '0'}
>
  <span class="rr-read-card-stripe"></span>
  <span class="rr-read-card-body">
    <span class="rr-read-card-cover-wrap">
      <span class="rr-read-card-glow"></span>
      <BookCover title={book.title} author={book.author} genre={book.genre} cover={book.cover} w={104} h={150} radius={5} />
    </span>
    <span class="rr-read-card-meta-top">
      <GenreTag genre={book.genre} />
      {typeof book.rating === 'number' && book.rating > 0 && (
        <StarRow value={book.rating} size={11} color={accentColor} />
      )}
    </span>
    <span class="rr-read-card-title">{book.title}</span>
    <span class="rr-read-card-author">{book.author}</span>
    <span class="rr-read-card-format">
      <FormatIcon format={book.format} size={11} />
      <span data-i18n="pl">{book.format === 'audiobook' ? 'AUDIO' : book.format === 'ebook' ? 'EBOOK' : 'PAPIER'}</span>
      <span data-i18n="en">{book.format === 'audiobook' ? 'AUDIO' : book.format === 'ebook' ? 'EBOOK' : 'PAPER'}</span>
      <span style="opacity:.5">·</span>
      <LangFlag lang={book.lang} size={9} />
      {book.lang === 'pl' ? 'PL' : 'EN'}
    </span>
  </span>
</a>

<style>
  .rr-read-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: var(--rr-bg-2);
    border: 1px solid var(--rr-line);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }
  .rr-read-card-stripe {
    display: block;
    height: 3px;
    background: oklch(0.82 0.16 var(--hue));
    opacity: 0.9;
  }
  .rr-read-card-body {
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .rr-read-card-cover-wrap {
    display: flex;
    justify-content: center;
    position: relative;
  }
  .rr-read-card-glow {
    position: absolute;
    inset: auto 0 -10px 0;
    height: 40px;
    filter: blur(14px);
    background: radial-gradient(ellipse, oklch(0.42 0.18 var(--hue) / 0.7), transparent 60%);
  }
  .rr-read-card-meta-top {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }
  .rr-read-card-title {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-family: var(--rr-sans);
    font-weight: 700;
    font-size: 13px;
    line-height: 1.15;
    color: var(--rr-ink);
    letter-spacing: -0.01em;
    min-height: 30px;
  }
  .rr-read-card-author {
    font-family: var(--rr-sans);
    font-size: 11px;
    color: var(--rr-muted);
  }
  .rr-read-card-format {
    font-family: var(--rr-mono);
    font-size: 10px;
    color: var(--rr-muted);
    letter-spacing: 0.08em;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }
</style>
