---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description, ogImage } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&display=swap"
      rel="stylesheet"
    />

    <link rel="alternate" type="application/rss+xml" title="Radek Reads RSS" href="/rss.xml" />

    <script is:inline>
      // Ustawia html[data-lang] PRZED pierwszym malowaniem, żeby przełącznik
      // PL/EN nie migał. Priorytet: localStorage -> navigator.language -> 'pl'.
      (function () {
        try {
          var saved = localStorage.getItem('rr-lang');
          var lang = saved === 'pl' || saved === 'en'
            ? saved
            : (navigator.language || '').toLowerCase().startsWith('pl') ? 'pl' : 'en';
          document.documentElement.dataset.lang = lang;
          document.documentElement.lang = lang;
        } catch (e) {
          document.documentElement.dataset.lang = 'pl';
        }
      })();
    </script>

    <style is:global>
      @import '../styles/global.css';
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
