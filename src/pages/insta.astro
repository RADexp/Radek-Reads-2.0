---
// Ekran "na telefon" do Instagram Stories. Pełnoekranowy, edge-to-edge,
// dostrojony pod iPhone (393x852, 19.5:9), safe-area dla Dynamic Island /
// home indicator. Pokazuje do 3 pozycji "Teraz czytam" (statycznie, bez query
// param interaktywności — strona jest w pełni statyczna SSG).
import BookCover from '../components/BookCover.astro';
import FormatIcon from '../components/FormatIcon.astro';
import LangFlag from '../components/LangFlag.astro';
import { genreInfo } from '../data/genres';
import { getBooks } from '../lib/notion';

const books = await getBooks();
const reading = books.filter((b) => b.shelf === 'reading').slice(0, 3);
const n = reading.length;
const coverH = { 1: 300, 2: 184, 3: 170 }[n] ?? 170;
const cols = n >= 3 ? 2 : 1;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Radek Reads — Teraz czytam</title>
    <meta name="robots" content="noindex" />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --rr-bg: #0b0820;
        --rr-ink: #f4f1ff;
        --rr-muted: #9e97c8;
        --rr-line: rgba(255, 255, 255, 0.08);
        --rr-sans: 'Space Grotesk', system-ui, sans-serif;
        --rr-mono: 'JetBrains Mono', ui-monospace, monospace;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
        background: var(--rr-bg);
      }
      body {
        font-family: var(--rr-sans);
        color: var(--rr-ink);
      }
    </style>
  </head>
  <body>
    <div class="rr-insta">
      <div class="rr-insta-kicker">
        <div class="rr-insta-domain">radekreads.pl</div>
        <h1 class="rr-insta-h1">Teraz czytam</h1>
        <div class="rr-insta-rule"></div>
      </div>

      <div class="rr-insta-grid-wrap">
        {n > 0 ? (
          <div class="rr-insta-grid" style={`grid-template-columns: repeat(${cols}, auto)`}>
            {reading.map((b) => {
              const hue = genreInfo(b.genre).hue;
              return (
                <div class="rr-insta-item">
                  <div class="rr-insta-cover-wrap">
                    <div class="rr-insta-glow" style={`background: radial-gradient(farthest-side, oklch(0.6 0.18 ${hue} / 0.8), oklch(0.6 0.18 ${hue} / 0.35) 55%, transparent 78%)`}></div>
                    <div class="rr-insta-cover">
                      <BookCover title={b.title} author={b.author} genre={b.genre} cover={b.cover} w={Math.round(coverH * 0.69)} h={coverH} radius={7} />
                    </div>
                  </div>
                  <div class="rr-insta-meta">
                    <div class="rr-insta-meta-row">
                      <span class="rr-insta-meta-item">
                        <FormatIcon format={b.format} size={12} color="var(--rr-muted)" />
                        {b.format === 'audiobook' ? 'AUDIO' : b.format === 'ebook' ? 'EBOOK' : 'PAPIER'}
                      </span>
                      <span style="opacity:.4">·</span>
                      <span class="rr-insta-meta-item">
                        <LangFlag lang={b.lang} size={10} />
                        {b.lang === 'pl' ? 'PL' : 'EN'}
                      </span>
                    </div>
                    {typeof b.progress === 'number' && (
                      <div class="rr-insta-progress">
                        <div class="rr-insta-progress-track">
                          <div class="rr-insta-progress-fill" style={`width:${b.progress}%`}></div>
                        </div>
                        <span class="rr-insta-progress-pct">{b.progress}%</span>
                      </div>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        ) : (
          <p class="rr-insta-empty">Brak danych</p>
        )}
      </div>
    </div>

    <style>
      .rr-insta {
        width: 100%;
        height: 100dvh;
        background: var(--rr-bg);
        color: var(--rr-ink);
        font-family: var(--rr-sans);
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
        padding-top: calc(env(safe-area-inset-top, 0px) + 36px);
        padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 40px);
        padding-left: calc(env(safe-area-inset-left, 0px) + 46px);
        padding-right: calc(env(safe-area-inset-right, 0px) + 46px);
        background-image: radial-gradient(120% 80% at 50% -10%, rgba(167, 139, 250, 0.1), transparent 55%);
      }
      .rr-insta-kicker {
        text-align: center;
        flex-shrink: 0;
      }
      .rr-insta-domain {
        font-family: var(--rr-mono);
        font-size: 11px;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--rr-muted);
      }
      .rr-insta-h1 {
        margin: 12px 0 0;
        font-family: var(--rr-sans);
        font-weight: 700;
        font-size: 30px;
        letter-spacing: -0.03em;
      }
      .rr-insta-rule {
        width: 34px;
        height: 2px;
        background: var(--rr-line);
        margin: 18px auto 0;
      }
      .rr-insta-grid-wrap {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 0;
        overflow: hidden;
      }
      .rr-insta-grid {
        display: grid;
        gap: 26px 30px;
        justify-content: center;
        align-items: start;
      }
      .rr-insta-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
      }
      .rr-insta-cover-wrap {
        position: relative;
        display: flex;
      }
      .rr-insta-glow {
        position: absolute;
        inset: -38%;
        border-radius: 50%;
        filter: blur(22px);
        pointer-events: none;
        z-index: 0;
      }
      .rr-insta-cover {
        position: relative;
        z-index: 1;
      }
      .rr-insta-meta {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 9px;
        width: 100%;
      }
      .rr-insta-meta-row {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: var(--rr-mono);
        font-size: 10.5px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--rr-muted);
      }
      .rr-insta-meta-item {
        display: inline-flex;
        align-items: center;
        gap: 5px;
      }
      .rr-insta-progress {
        width: 100%;
        display: flex;
        align-items: center;
        gap: 9px;
      }
      .rr-insta-progress-track {
        flex: 1;
        height: 3px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 99px;
        overflow: hidden;
      }
      .rr-insta-progress-fill {
        height: 100%;
        background: var(--rr-ink);
        opacity: 0.9;
        border-radius: 99px;
      }
      .rr-insta-progress-pct {
        font-family: var(--rr-mono);
        font-size: 12px;
        font-weight: 500;
        color: var(--rr-ink);
        font-variant-numeric: tabular-nums;
      }
      .rr-insta-empty {
        font-family: var(--rr-mono);
        color: var(--rr-muted);
      }
    </style>
  </body>
</html>
